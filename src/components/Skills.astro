---
import { t } from '../utils/i18n';
import { SKILL_GROUPS, CONSTELLATION } from '../data/site';
---

<section id="skills" class="section">
  <h2 class="section-title" data-reveal data-i18n="skills.title">{t('skills.title')}</h2>

  <div data-reveal class="card relative mb-8 overflow-hidden p-2">
    <canvas
      id="constellation"
      class="h-[240px] w-full sm:h-[280px]"
      role="img"
      aria-label="Interactive constellation of related technologies"></canvas>
    <p class="pb-2 text-center text-xs text-txt-3" data-i18n="skills.hint">{t('skills.hint')}</p>
  </div>
  <script
    type="application/json"
    id="constellation-data"
    set:html={JSON.stringify(CONSTELLATION)}
  />

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      SKILL_GROUPS.map((group) => (
        <div data-reveal>
          <h3
            class="mb-3 font-heading text-base font-bold text-accent"
            data-i18n={`skills.${group.key}`}
          >
            {t(`skills.${group.key}`)}
          </h3>
          <ul class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <li class="badge">{skill}</li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
