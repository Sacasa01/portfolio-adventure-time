---
import { t } from '../utils/i18n';
import { SKILL_GROUPS, CONSTELLATION } from '../data/site';
---
<section id="skills" class="section">
  <h2 class="section-title" data-reveal data-i18n="skills.title">{t('skills.title')}</h2>

  <div data-reveal class="card relative mb-12 overflow-hidden p-2">
    <canvas id="constellation" class="h-[320px] w-full sm:h-[380px]" role="img" aria-label="Interactive constellation of related technologies"></canvas>
    <p class="pb-3 text-center text-xs text-txt-3" data-i18n="skills.hint">{t('skills.hint')}</p>
  </div>
  <script type="application/json" id="constellation-data" set:html={JSON.stringify(CONSTELLATION)} />

  <div class="grid gap-10 sm:grid-cols-2">
    {SKILL_GROUPS.map((group) => (
      <div data-reveal>
        <h3 class="mb-5 font-heading text-lg font-bold text-accent" data-i18n={`skills.${group.key}`}>{t(`skills.${group.key}`)}</h3>
        <ul class="space-y-4">
          {group.skills.map((s) => (
            <li>
              <div class="mb-1.5 flex justify-between text-sm">
                <span class="text-txt-1">{s.name}</span>
                <span class="text-txt-3">{s.level}%</span>
              </div>
              <div class="skill-bar"><span data-level={s.level}></span></div>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
