---
import { t } from '../utils/i18n';
const entries = ['bsc', 'hnd', 'aws'] as const;
---
<section id="education" class="section">
  <h2 class="section-title" data-reveal data-i18n="edu.title">{t('edu.title')}</h2>
  <div class="grid gap-6 md:grid-cols-3">
    {entries.map((e) => (
      <article class="card flex flex-col p-6" data-reveal>
        <div class="flex items-start justify-between gap-3">
          <p class="text-xs font-semibold uppercase tracking-wider text-accent" data-i18n={`edu.${e}.date`}>{t(`edu.${e}.date`)}</p>
          {e === 'aws' && <span class="badge" data-i18n="edu.aws.badge">{t('edu.aws.badge')}</span>}
        </div>
        <h3 class="mt-2 font-heading text-lg font-bold" data-i18n={`edu.${e}.name`}>{t(`edu.${e}.name`)}</h3>
        <p class="mt-1 text-sm text-txt-2" data-i18n={`edu.${e}.org`}>{t(`edu.${e}.org`)}</p>
        <p class="mt-3 text-sm text-txt-3" data-i18n={`edu.${e}.desc`}>{t(`edu.${e}.desc`)}</p>
      </article>
    ))}
  </div>
</section>
