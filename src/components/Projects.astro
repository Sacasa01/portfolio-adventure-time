---
import { t } from '../utils/i18n';
import { PROJECTS } from '../data/site';

const bentoSizes = ['bento-lg', 'bento-wide'] as const;
---

<section id="projects" class="section">
  <h2 class="section-title" data-reveal data-i18n="projects.title">{t('projects.title')}</h2>
  <div class="bento-grid">
    {
      PROJECTS.map((p, i) => (
        <article
          id={`project-${p.id}`}
          class={`project-card card flex flex-col p-7 ${bentoSizes[i % bentoSizes.length]}`}
          data-reveal
          data-title={p.title}
          data-tech={JSON.stringify(p.tech)}
          data-links={JSON.stringify(p.links)}
        >
          <h3 class="font-heading text-2xl font-bold">{p.title}</h3>
          <p class="mt-1 text-sm font-medium text-accent" data-i18n={`projects.${p.id}.tagline`}>
            {t(`projects.${p.id}.tagline`)}
          </p>
          <p class="mt-3 flex-1 text-txt-2" data-i18n={`projects.${p.id}.desc`}>
            {t(`projects.${p.id}.desc`)}
          </p>
          <div class="mt-5 flex flex-wrap gap-2">
            {p.tech.map((b) => (
              <span class="badge">{b}</span>
            ))}
          </div>
          <button
            class="btn btn-ghost mt-6 self-start"
            data-open-project={p.id}
            data-i18n="projects.open"
          >
            {t('projects.open')}
          </button>
        </article>
      ))
    }
  </div>

  <dialog id="project-modal" aria-labelledby="modal-title">
    <div class="p-8">
      <div class="flex items-start justify-between gap-4">
        <h3 id="modal-title" class="font-heading text-2xl font-bold"></h3>
        <button
          id="modal-close"
          class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full text-txt-2 hover:text-accent"
          aria-label={t('projects.close')}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"></path></svg
          >
        </button>
      </div>
      <p id="modal-details" class="mt-4 leading-relaxed text-txt-2"></p>
      <h4
        class="mt-6 font-heading text-sm font-bold uppercase tracking-wider text-txt-3"
        data-i18n="projects.stack"
      >
        {t('projects.stack')}
      </h4>
      <div id="modal-tech" class="mt-3 flex flex-wrap gap-2"></div>
      <div id="modal-links" class="mt-6 flex flex-wrap gap-3"></div>
    </div>
  </dialog>
</section>
