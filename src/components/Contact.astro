---
import { t } from '../utils/i18n';
import { SITE } from '../data/site';
---
<section id="contact" class="section">
  <h2 class="section-title" data-reveal data-i18n="contact.title">{t('contact.title')}</h2>
  <div class="grid gap-10 md:grid-cols-2">
    <div data-reveal>
      <p class="text-lg text-txt-2" data-i18n="contact.subtitle">{t('contact.subtitle')}</p>
      <p class="mt-4 font-semibold text-accent" data-i18n="contact.location">{t('contact.location')}</p>
      <ul class="mt-6 space-y-2 text-sm">
        <li>
          <a class="inline-flex min-h-11 items-center gap-3 text-txt-2 hover:text-accent" href={`mailto:${SITE.email}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-10 7L2 7"></path></svg>
            {SITE.email}
          </a>
        </li>
        <li>
          <a class="inline-flex min-h-11 items-center gap-3 text-txt-2 hover:text-accent" href={`tel:${SITE.phone.replace(/\s/g, '')}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            {SITE.phone}
          </a>
        </li>
        <li>
          <a class="inline-flex min-h-11 items-center gap-3 text-txt-2 hover:text-accent" href={SITE.linkedin} target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
        </li>
        <li>
          <a class="inline-flex min-h-11 items-center gap-3 text-txt-2 hover:text-accent" href={SITE.github} target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
            GitHub
          </a>
        </li>
      </ul>
    </div>

    <form id="contact-form" data-reveal novalidate>
      <input type="hidden" name="access_key" value={SITE.web3formsKey} />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
      <div class="field">
        <input id="cf-name" name="name" type="text" placeholder=" " autocomplete="name" />
        <label for="cf-name" data-i18n="contact.name">{t('contact.name')}</label>
        <p class="field-error" aria-live="polite"></p>
      </div>
      <div class="field">
        <input id="cf-email" name="email" type="email" placeholder=" " autocomplete="email" />
        <label for="cf-email" data-i18n="contact.email">{t('contact.email')}</label>
        <p class="field-error" aria-live="polite"></p>
      </div>
      <div class="field">
        <textarea id="cf-message" name="message" rows="5" placeholder=" "></textarea>
        <label for="cf-message" data-i18n="contact.message">{t('contact.message')}</label>
        <p class="field-error" aria-live="polite"></p>
      </div>
      <button type="submit" class="btn btn-primary w-full" data-i18n="contact.send">{t('contact.send')}</button>
      <p id="form-status" class="mt-4" aria-live="polite"></p>
    </form>
  </div>
</section>
